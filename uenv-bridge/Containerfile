ARG BASE_IMAGE=docker.io/verlai/verl:vllm011.latest
FROM ${BASE_IMAGE}

USER root

ENV UENV_BRIDGE_HOME=/workspace/uenv-bridge
ENV PYTHONPATH=/workspace/uenv-bridge/src

WORKDIR /workspace/uenv-bridge

COPY pyproject.toml README.md ./
COPY src ./src
COPY scripts ./scripts
COPY docs ./docs
COPY configs ./configs
COPY tests ./tests

RUN python -m pip install --no-cache-dir -e . && \
    python -c "import uenv.bridge; print('uenv-bridge import ok')"

ENTRYPOINT ["/bin/bash"]
CMD ["-lc", "python -c 'import uenv.bridge; print(\"uenv-bridge image ready\")' && exec bash"]
