<mxfile host="app.diagrams.net" modified="2026-07-14T00:00:00.000Z" agent="Codex" version="26.0.14" type="device">
  <diagram id="verl-uenv-fully-async-flow" name="VeRL UEnv Fully Async Flow">
    <mxGraphModel dx="1840" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1840" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="VeRL fully_async 接入 UEnv：接出点、回接点与 VeRL MessageQueue" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=26;fontStyle=1;fontColor=#172033" parent="1" vertex="1"><mxGeometry x="40" y="22" width="1200" height="40" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="UEnv 不实现异步结果队列：每个 episode 在 AgentLoop 内完成 request / result 往返；完成后的 RolloutSample 由 VeRL 的 MessageQueue 在 Rollouter 和 Trainer 之间传递。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontColor=#475569" parent="1" vertex="1"><mxGeometry x="40" y="66" width="1660" height="24" as="geometry"/></mxCell>
        <mxCell id="control" value="VeRL fully_async_policy 控制面" style="swimlane;html=1;rounded=0;startSize=34;fillColor=#f8fafc;swimlaneFillColor=#e0f2fe;strokeColor=#0284c7;fontStyle=1;fontSize=16;fontColor=#0c4a6e" parent="1" vertex="1"><mxGeometry x="30" y="112" width="1780" height="168" as="geometry"/></mxCell>
        <mxCell id="taskrunner" value="&lt;b&gt;FullyAsyncTaskRunner._initialize_components()&lt;/b&gt;&lt;br&gt;创建 FullyAsyncRollouter、FullyAsyncTrainer&lt;br&gt;创建 MessageQueue Ray Actor，并向两端注入 MessageQueueClient&lt;br&gt;并发启动 rollouter.fit() 与 trainer.fit()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=14;align=left;spacingLeft=12;fontColor=#1e3a8a" parent="1" vertex="1"><mxGeometry x="70" y="165" width="720" height="82" as="geometry"/></mxCell>
        <mxCell id="queue-control" value="&lt;b&gt;VeRL MessageQueue（Ray Actor）&lt;/b&gt;&lt;br&gt;deque + async condition；非 UEnv 组件&lt;br&gt;max_queue_size、生产 / 消费 / 丢弃统计" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=14;align=left;spacingLeft=12;fontColor=#78350f" parent="1" vertex="1"><mxGeometry x="1040" y="165" width="420" height="82" as="geometry"/></mxCell>
        <mxCell id="e-control" value="MessageQueueClient" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#0284c7;fontSize=12;fontColor=#0c4a6e;labelBackgroundColor=#ffffff" parent="1" source="taskrunner" target="queue-control" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rollout-lane" value="1. Rollouter 从 VeRL AgentLoop 接出，调用 UEnv 完成单条 rollout" style="swimlane;html=1;rounded=0;startSize=34;fillColor=#f8fafc;swimlaneFillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;fontSize=16;fontColor=#1e3a8a" parent="1" vertex="1"><mxGeometry x="30" y="310" width="1780" height="480" as="geometry"/></mxCell>
        <mxCell id="rollouter" value="&lt;b&gt;FullyAsyncRollouter&lt;/b&gt;&lt;br&gt;_process_single_sample_&lt;br&gt;streaming()&lt;br&gt;RolloutSample&lt;br&gt;full_batch: DataProto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=14;fontColor=#1e3a8a" parent="1" vertex="1"><mxGeometry x="70" y="385" width="210" height="105" as="geometry"/></mxCell>
        <mxCell id="manager" value="&lt;b&gt;FullyAsyncAgentLoopManager&lt;/b&gt;&lt;br&gt;generate_sequences_single()&lt;br&gt;选择 AgentLoopWorker 并发起 Ray RPC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=14;fontColor=#1e3a8a" parent="1" vertex="1"><mxGeometry x="330" y="385" width="220" height="105" as="geometry"/></mxCell>
        <mxCell id="worker" value="&lt;b&gt;AgentLoopWorker&lt;/b&gt;&lt;br&gt;generate_sequences()&lt;br&gt;&lt;b&gt;接出点：批量补丁识别 uenv_agent&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bfdbfe;strokeColor=#1d4ed8;strokeWidth=3;fontSize=14;fontColor=#172554" parent="1" vertex="1"><mxGeometry x="600" y="385" width="230" height="105" as="geometry"/></mxCell>
        <mxCell id="adapter" value="&lt;b&gt;UEnvAgentLoop.run_batch()&lt;/b&gt;&lt;br&gt;构建 EpisodeRequest&lt;br&gt;parallel_mode = fully_async&lt;br&gt;字段见下方 Request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=14;fontColor=#0c4a6e" parent="1" vertex="1"><mxGeometry x="880" y="385" width="240" height="105" as="geometry"/></mxCell>
        <mxCell id="core" value="&lt;b&gt;Rust Adapter Core&lt;/b&gt;&lt;br&gt;ExecuteBatchStream&lt;br&gt;按 request_id 对齐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=14;fontColor=#0c4a6e" parent="1" vertex="1"><mxGeometry x="1170" y="385" width="180" height="105" as="geometry"/></mxCell>
        <mxCell id="uenv" value="&lt;b&gt;UEnv Server / Worker&lt;/b&gt;&lt;br&gt;调度环境 / 工具、调用模型&lt;br&gt;写入 reward、trajectory、token logprobs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=14;fontColor=#7c2d12" parent="1" vertex="1"><mxGeometry x="1400" y="385" width="230" height="105" as="geometry"/></mxCell>
        <mxCell id="model" value="&lt;b&gt;VeRL rollout model endpoint&lt;/b&gt;&lt;br&gt;/v1/chat/completions，logprobs=true&lt;br&gt;body: uenv_model_version&lt;br&gt;header: version fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fae8ff;strokeColor=#9333ea;fontSize=14;fontColor=#581c87" parent="1" vertex="1"><mxGeometry x="1480" y="540" width="280" height="92" as="geometry"/></mxCell>
        <mxCell id="request" value="&lt;b&gt;EpisodeRequest&lt;/b&gt;&lt;br&gt;request_id / batch_id / sample_index&lt;br&gt;generation_config / model_endpoint&lt;br&gt;metadata.parallel_mode = fully_async" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#60a5fa;fontSize=13;align=left;spacingLeft=10;fontColor=#1e3a8a" parent="1" vertex="1"><mxGeometry x="880" y="540" width="390" height="90" as="geometry"/></mxCell>
        <mxCell id="result" value="&lt;b&gt;EpisodeResult / StepRecord.info&lt;/b&gt;&lt;br&gt;response_ids / response_mask / reward / trajectory&lt;br&gt;parallel_mode + rollout_param_version + rollout_policy_version&lt;br&gt;rollout_log_probs 与 response_ids 对齐" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontSize=13;align=left;spacingLeft=10;fontColor=#7c2d12" parent="1" vertex="1"><mxGeometry x="850" y="665" width="590" height="94" as="geometry"/></mxCell>
        <mxCell id="e-rollouter-manager" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2563eb" parent="1" source="rollouter" target="manager" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-manager-worker" value="Ray RPC" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#2563eb;fontSize=12;fontColor=#1e3a8a;labelBackgroundColor=#ffffff" parent="1" source="manager" target="worker" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-worker-adapter" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=3;strokeColor=#1d4ed8" parent="1" source="worker" target="adapter" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-adapter-core" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#0284c7" parent="1" source="adapter" target="core" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-core-uenv" value="请求派发" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#ea580c;fontSize=12;fontColor=#7c2d12;labelBackgroundColor=#ffffff" parent="1" source="core" target="uenv" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-adapter-request" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=none;strokeColor=#60a5fa" parent="1" source="adapter" target="request" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-uenv-model" value="OpenAI-compatible 请求" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9333ea;fontSize=12;fontColor=#581c87;labelBackgroundColor=#ffffff" parent="1" source="uenv" target="model" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-model-uenv" value="tokens + logprobs + version" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9333ea;fontSize=12;fontColor=#581c87;labelBackgroundColor=#ffffff" parent="1" source="model" target="uenv" edge="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1700" y="510"/></Array></mxGeometry></mxCell>
        <mxCell id="e-uenv-result" value="结果回传" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#ea580c;fontSize=12;fontColor=#7c2d12;labelBackgroundColor=#ffffff" parent="1" source="uenv" target="result" edge="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1515" y="640"/></Array></mxGeometry></mxCell>
        <mxCell id="return-lane" value="2. 结果从 AgentLoop 回接到 VeRL DataProto，再进入 VeRL MessageQueue 供 Trainer 消费" style="swimlane;html=1;rounded=0;startSize=34;fillColor=#f8fafc;swimlaneFillColor=#f0fdf4;strokeColor=#16a34a;fontStyle=1;fontSize=16;fontColor=#14532d" parent="1" vertex="1"><mxGeometry x="30" y="825" width="1780" height="350" as="geometry"/></mxCell>
        <mxCell id="output" value="&lt;b&gt;UEnvAgentLoop._output_from_result()&lt;/b&gt;&lt;br&gt;AgentLoopOutput：response_ids / response_mask / reward&lt;br&gt;response_logprobs = rollout_log_probs&lt;br&gt;extra_fields: global_steps / min / max&lt;br&gt;（来自 rollout_param_version）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=13;align=left;spacingLeft=10;fontColor=#0c4a6e" parent="1" vertex="1"><mxGeometry x="100" y="910" width="350" height="138" as="geometry"/></mxCell>
        <mxCell id="postprocess" value="&lt;b&gt;AgentLoopWorker&lt;/b&gt;&lt;br&gt;_agent_loop_postprocess()&lt;br&gt;+ _postprocess()&lt;br&gt;&lt;b&gt;回接点：AgentLoopOutput -&gt; DataProto&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#16a34a;strokeWidth=3;fontSize=14;fontColor=#14532d" parent="1" vertex="1"><mxGeometry x="490" y="910" width="320" height="138" as="geometry"/></mxCell>
        <mxCell id="rollouter-return" value="&lt;b&gt;FullyAsyncRollouter&lt;/b&gt;&lt;br&gt;ret -&gt; RolloutSample.full_batch&lt;br&gt;message_queue_client.put_sample()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=14;fontColor=#1e3a8a" parent="1" vertex="1"><mxGeometry x="870" y="920" width="260" height="118" as="geometry"/></mxCell>
        <mxCell id="queue" value="&lt;b&gt;VeRL MessageQueue（Ray Actor）&lt;/b&gt;&lt;br&gt;put_sample(RolloutSample)&lt;br&gt;队满丢弃最旧样本；通知 consumer&lt;br&gt;&lt;b&gt;UEnv 不创建 / 不持有此队列&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;strokeWidth=3;fontSize=14;align=left;spacingLeft=10;fontColor=#78350f" parent="1" vertex="1"><mxGeometry x="1200" y="900" width="290" height="158" as="geometry"/></mxCell>
        <mxCell id="trainer" value="&lt;b&gt;FullyAsyncTrainer&lt;/b&gt;&lt;br&gt;_get_samples_from_queue()&lt;br&gt;get_sample -&gt; 组装训练 batch&lt;br&gt;fit_step: ratio / loss&lt;br&gt;actor update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;align=left;spacingLeft=10;fontColor=#14532d" parent="1" vertex="1"><mxGeometry x="1550" y="910" width="230" height="138" as="geometry"/></mxCell>
        <mxCell id="e-result-output" value="Server -&gt; Core -&gt; Adapter 回传" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#ea580c;fontSize=12;fontColor=#7c2d12;labelBackgroundColor=#ffffff" parent="1" source="result" target="output" edge="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="800" y="712"/><mxPoint x="800" y="880"/><mxPoint x="450" y="880"/></Array></mxGeometry></mxCell>
        <mxCell id="e-output-postprocess" value="AgentLoopOutput" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#0284c7;fontSize=12;fontColor=#0c4a6e;labelBackgroundColor=#ffffff" parent="1" source="output" target="postprocess" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-postprocess-rollouter" value="返回 DataProto" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#16a34a;fontSize=12;fontColor=#14532d;labelBackgroundColor=#ffffff" parent="1" source="postprocess" target="rollouter-return" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-rollouter-queue" value="put_sample" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=3;strokeColor=#d97706;fontSize=12;fontColor=#78350f;labelBackgroundColor=#ffffff" parent="1" source="rollouter-return" target="queue" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-queue-trainer" value="get_sample" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=3;strokeColor=#d97706;fontSize=12;fontColor=#78350f;labelBackgroundColor=#ffffff" parent="1" source="queue" target="trainer" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e-trainer-sync" value="checkpoint_manager.update_weights() + reset_staleness()&lt;br&gt;NCCL 参数同步到 Rollouter / rollout endpoint" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#16a34a;fontSize=12;fontColor=#14532d;labelBackgroundColor=#ffffff" parent="1" source="trainer" target="rollouter-return" edge="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1690" y="870"/><mxPoint x="1050" y="870"/></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
