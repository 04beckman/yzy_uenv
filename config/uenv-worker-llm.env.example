# Worker 侧 LLM 配置（复制为 uenv-worker-llm.env 后按实机填写）
# 加载路径可通过 UENV_WORKER_LLM_ENV 覆盖，默认 config/uenv-worker-llm.env
#
# AgentLoop 预 rollout 时，Worker ModelClient 通过 OpenRouter 生成 GSM8K 答案。
# API Key 勿提交仓库；可写入 7143 的 /root/.uenv-worker.env 或本文件。

UENV_LLM_PROVIDER=openrouter
UENV_LLM_ENDPOINT=https://openrouter.ai/api/v1
UENV_LLM_MODEL_NAME=qwen/qwen-2.5-7b-instruct
UENV_LLM_API_KEY=sk-or-v1-xxxxxxxx
UENV_LLM_HTTP_REFERER=https://github.com/your-org/UEnv
UENV_LLM_APP_TITLE=UEnv
UENV_LLM_MAX_TOKENS=512
UENV_LLM_TEMPERATURE=1.0
