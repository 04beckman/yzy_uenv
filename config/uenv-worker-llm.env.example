# Worker 侧 LLM 默认配置（复制为 uenv-worker-llm.env 后按实机填写）
# 加载路径可通过 UENV_WORKER_LLM_ENV 覆盖，默认 config/uenv-worker-llm.env
#
# ModelClient 默认使用本文件配置；仅当 Episode payload 含有效 model_endpoint 时才 override。
# API Key 勿提交仓库。

UENV_LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
UENV_LLM_MODEL_NAME=deepseek-v4-flash
UENV_LLM_API_KEY=sk-xxxxxxxx
UENV_LLM_MAX_TOKENS=512
UENV_LLM_TEMPERATURE=1.0
# HTTP 单次请求超时（秒）；默认 600，覆盖 OlymMATH thinking 长生成
UENV_LLM_HTTP_TIMEOUT_SECS=600
# LLM 失败重试次数（默认 3）
UENV_LLM_MAX_RETRIES=3
# Worker 单 episode 执行上限（秒）；默认 600，可被 EpisodeRequest.timeout_seconds 抬高
# UENV_WORKER_EPISODE_TIMEOUT_SECS=600
# DispatchEpisode 执行期 progress heartbeat 间隔（秒）
# UENV_WORKER_DISPATCH_HEARTBEAT_SECS=15
# 同步回传 response_text / action 最大字符数（reward 已用完整文本计算）
# UENV_WORKER_MAX_RESPONSE_TEXT_CHARS=8192
# gRPC HTTP/2 keepalive / max message（见 uenv-worker runtime）
# UENV_WORKER_GRPC_HTTP2_KEEPALIVE_INTERVAL_SECS=30
# UENV_WORKER_GRPC_HTTP2_KEEPALIVE_TIMEOUT_SECS=10
# UENV_WORKER_GRPC_TCP_KEEPALIVE_SECS=60
# UENV_WORKER_GRPC_MAX_MESSAGE_BYTES=16777216
