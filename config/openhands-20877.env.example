# OpenHands on 阿里云 8C32G (8.130.208.77)
# Copy to /root/.openhands-20877.env on 208.77 (chmod 600)

UENV_REPO=/root/UEnv
OPENHANDS_BENCHMARKS_DIR=/opt/openhands/benchmarks
OPENHANDS_SDK_DIR=/opt/openhands/benchmarks/vendor/software-agent-sdk
OPENHANDS_RUNS_DIR=/var/log/uenv/openhands-runs

# 7143 Worker Runtime Gateway — 经 SSH 隧道（208.77 本机，无需 A100 公网 NAT）
UENV_GATEWAY=http://127.0.0.1:28097
UENV_GATEWAY_API_KEY=swe-pro-secret

# LLM：7142 本地模型网关（公网）或 DashScope 云端
UENV_LLM_ENDPOINT=http://219.147.100.43:18888/v1
UENV_LLM_MODEL_NAME=DeepSeek-V3-0324-AWQ
# UENV_LLM_API_KEY=from /root/.uenv-llm-gateway.env on 7142 or local secret

# SWE-Pro baseline / Agent：较长修复轨迹需要较大输出与总超时（见 Docs/260713 §2.3）
# OPENHANDS_MAX_OUTPUT_TOKENS=32768
# OPENHANDS_ENABLE_THINKING=1
# OPENHANDS_RUN_TIMEOUT_SEC=7200
# OPENHANDS_AGENT_MAX_CONCURRENT=1

# Trajectory v2.2 — Server 聚合验收（与 7143 Worker 共用 token）
# source /root/.uenv-trajectory.env on 208.77
UENV_TRAJECTORY_ENDPOINT=http://8.130.75.157:8077
# UENV_TRAJECTORY_TOKEN=see /root/.uenv-trajectory.env

# Runner HTTP 服务
OPENHANDS_RUNNER_API_BIND=0.0.0.0:8888
OPENHANDS_RUNNER_HEALTH_BIND=0.0.0.0:8777

# Server 编排（Agent 池 poll）：CompleteAgentJob 必须带注册后的 agent_id
# OPENHANDS_AGENT_POLL=1
# UENV_SERVER_ENDPOINT=8.130.75.157:8088
# OPENHANDS_AGENT_POOL_ID=openhands-default
# UENV_GATEWAY_LOCAL=http://127.0.0.1:28097
