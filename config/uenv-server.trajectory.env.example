# Copy to Server (8.130.75.157) as /root/.uenv-server.env (chmod 600)
# Used together with uenv-adapter-core (gRPC :8088 + trajectory HTTP :8077)

export UENV_ADDR=0.0.0.0:8088
export UENV_CONFIG_PATH=/root/UEnv/config/server.yaml

# Trajectory v2.2 aggregation
export UENV_TRAJECTORY_ENABLED=1
export UENV_TRAJECTORY_HTTP_LISTEN=0.0.0.0:8077
export UENV_TRAJECTORY_DATA_DIR=/var/lib/uenv/trajectory-data
export UENV_TRAJECTORY_TOKEN=uenv-trj-shared-lab-2026
